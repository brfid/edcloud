# Optional environment file for local operator automation.
# Copy to: ~/.config/edcloud/edc.env

# Repo checkout used by ~/.local/bin/edc wrapper.
EDCLOUD_REPO=$HOME/edcloud

# Optional AWS profile for local orchestration.
# AWS_PROFILE=default

# Needed for first-time provision or reprovision.
# Do not commit real values.
# TAILSCALE_AUTH_KEY=tskey-auth-...
