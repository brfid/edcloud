# Optional environment file for local operator automation.
# Copy to: ~/.config/edcloud/edc.env

# Repo checkout used by ~/.local/bin/edc wrapper.
EDCLOUD_REPO=$HOME/edcloud

# Optional AWS profile for local orchestration.
# AWS_PROFILE=default
# Optional region override.
# AWS_DEFAULT_REGION=us-east-1

# Default SSM parameter for provision/reprovision key lookup.
TAILSCALE_AUTH_KEY_SSM_PARAMETER=/edcloud/tailscale_auth_key

# Optional local key cache for repeated provision workflows.
# Populate via:
#   eval "$(edc load-tailscale-env-key)"
# Do not commit real values.
# TAILSCALE_AUTH_KEY=tskey-auth-...
